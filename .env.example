# Database
POSTGRES_DB=bolaocopa
POSTGRES_USER=bolaocopa
POSTGRES_PASSWORD=changeme

# Authentication
JWT_SECRET=generate-with-openssl-rand-hex-32
ALLOWED_ORIGINS=https://bolao.seu-dominio.com

# Google OAuth (criar em console.cloud.google.com)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
