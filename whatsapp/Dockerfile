# PROTOTYPE — throwaway
FROM golang:1.25-alpine AS builder

RUN apk add --no-cache gcc musl-dev sqlite-dev

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=1 GOOS=linux go build -o /bin/whatsapp ./cmd/whatsapp

FROM alpine:3.19
RUN apk add --no-cache ca-certificates sqlite-libs

WORKDIR /app
COPY --from=builder /bin/whatsapp .

VOLUME ["/data"]

EXPOSE 9090
CMD ["/app/whatsapp"]
